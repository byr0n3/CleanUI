<div @attributes="@(AdditionalAttributes)"
     class="alert @(TypeClass) @(AdditionalAttributes.GetString("class") ?? "")"
     role="alert">
     @if (TitleContent is not null)
     {
          @(Title)
     }
     else if (ShowIcon || (IconContent is not null))
     {
          <span class="alert-icon">
               @(Icon)
          </span>
     }

     @(ChildContent)
</div>
