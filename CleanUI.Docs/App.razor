@using CleanUI.Docs.Extensions
@using CleanUI.Docs.Models
@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en" data-theme="@(HttpContext.RequestTheme.GetValue())">

	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<base href="/" />
		<ResourcePreloader />
		<link rel="stylesheet" href="@(Assets["css/app.css"])" />
		<link rel="stylesheet" href="@(Assets["CleanUI.Docs.styles.css"])" />
		<link rel="stylesheet" href="@(Assets["_content/CleanUI/theme.css"])"/>
		<link rel="stylesheet" href="@(Assets["_content/CleanUI/base.css"])"/>
		<link rel="stylesheet" href="@(Assets["_content/CleanUI/components.css"])"/>
		<link rel="stylesheet" href="@(Assets["_content/CleanUI/utilities.css"])"/>
		<link rel="stylesheet" href="@(Assets["css/github-dark.min.css"])" />
		<ImportMap />
		<HeadOutlet />
		<link rel="icon" type="image/png" href="@(Assets["favicon-96x96.png"])" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="@(Assets["favicon.svg"])" />
		<link rel="shortcut icon" href="@(Assets["favicon.ico"])" />
		<link rel="apple-touch-icon" sizes="180x180" href="@(Assets["apple-touch-icon.png"])" />
		<link rel="manifest" href="@(Assets["site.webmanifest"])" />
		<meta name="apple-mobile-web-app-title" content="CleanUI" />
	</head>

	<body class="d-flex">
		<Routes />

		<script src="@(Assets["_framework/blazor.web.js"])"></script>
		
		<script src="@(Assets["_content/CleanUI/modal.js"])"></script>
		<script src="@(Assets["_content/CleanUI/toast.js"])"></script>
		<script src="@(Assets["_content/CleanUI/tooltip.js"])"></script>
		
		<script src="@(Assets["js/theme.js"])"></script>
		<script src="@(Assets["js/copy.js"])"></script>
		
		<script src="@(Assets["js/highlight.min.js"])"></script>
		<script src="@(Assets["js/csharp.min.js"])"></script>
		<script src="@(Assets["js/cshtml-razor.min.js"])"></script>
		<script>
			// Highlight all code examples after the page has loaded.
			document.addEventListener('DOMContentLoaded', function () {
				hljs.highlightAll();

				// Highlight all code examples when Blazor triggers enhanced navigation.
				Blazor.addEventListener('enhancedload', function () {
					hljs.highlightAll();
				});
			});
		</script>
	</body>

</html>

@code {

	[CascadingParameter] public required HttpContext HttpContext { get; init; }

}
