<CleanButton ButtonType="@(CleanButtonType.Primary)" onclick="window.Modal.open('basic-modal')">
	Open modal
</CleanButton>

<CleanModal Id="basic-modal" Title="A simple modal!">
	<ChildContent>
		This is the modal's content.
	</ChildContent>
	
	<FooterContent>
		<CleanButton ButtonType="@(CleanButtonType.Primary)" onclick="window.Modal.close('basic-modal')">
			OK
		</CleanButton>
	</FooterContent>
</CleanModal>
