<CleanButton ButtonType="@(CleanButtonType.Primary)" onclick="window.Modal.open('unclosable-modal')">
	Open unclosable modal
</CleanButton>

<CleanModal Id="unclosable-modal" Closable="false">
	<ChildContent>
		This modal is not closable.
	</ChildContent>

	<FooterContent>
		<CleanButton ButtonType="@(CleanButtonType.Danger)" onclick="window.Modal.close('unclosable-modal')">
			Close anyway :)
		</CleanButton>
	</FooterContent>
</CleanModal>

@code {

	public static RenderFragment Description =>
		@<p>Using the JavaScript <code>window.Modal.close</code> method will close the modal anyway.</p>;

}
