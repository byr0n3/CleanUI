<div class="p-relative" style="width: 16em;height: 8em">
	<CleanButton class="p-absolute inset-bs-0"
	             style="inset-inline-start: 5em"
	             popovertarget="popover"
	             popovertargetaction="toggle">
		Default
	</CleanButton>
	<CleanButton class="p-absolute inset-ie-0"
	             style="inset-block-start: 2.5em"
	             popovertarget="popover-right"
	             popovertargetaction="toggle">
		Right
	</CleanButton>
	<CleanButton class="p-absolute inset-be-0"
	             style="inset-inline-start: 5em"
	             popovertarget="popover-bottom"
	             popovertargetaction="toggle">
		Bottom
	</CleanButton>
	<CleanButton class="p-absolute inset-is-0"
	             style="inset-block-start: 2.5em"
	             popovertarget="popover-left"
	             popovertargetaction="toggle">
		Left
	</CleanButton>
</div>

<CleanPopover id="popover">
	This popover is aligned to the top.
</CleanPopover>
<CleanPopover id="popover-right" Position="@(CleanPopoverPosition.Right)">
	This popover is aligned to the right.
</CleanPopover>
<CleanPopover id="popover-bottom" Position="@(CleanPopoverPosition.Bottom)">
	This popover is aligned to the bottom.
</CleanPopover>
<CleanPopover id="popover-left" Position="@(CleanPopoverPosition.Left)">
	This popover is aligned to the left.
</CleanPopover>
